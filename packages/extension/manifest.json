{
    "name": "Zelto",
    "version": "1.3.0",
    "manifest_version": 3,
    "default_locale": "zh_CN",
    "description": "__MSG_description__",
    "icons": {
        "16": "assets/icons/icon16.png",
        "32": "assets/icons/icon32.png",
        "48": "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "assets/icons/icon16.png",
            "32": "assets/icons/icon32.png",
            "48": "assets/icons/icon48.png",
            "128": "assets/icons/icon128.png"
        },
        "default_title": "Settings"
    },
    "options_ui": {
        "page": "views/options/index.html",
        "open_in_tab": true
    },
    "background": {
        "service_worker": "scripts/background.js",
        "scripts": [
            "scripts/background.js"
        ]
    },
    "content_scripts": [
        {
            "js": [
                "scripts/zpin.min.js"
            ],
            "matches": [
                "https://www.zhaopin.com/sou/*"
            ],
            "run_at": "document_end"
        },
        {
            "js": [
                "scripts/yupao.min.js"
            ],
            "matches": [
                "https://www.yupao.com/zhaogong/*"
            ],
            "run_at": "document_end"
        },
        {
            "js": [
                "scripts/zhipin.min.js"
            ],
            "matches": [
                "https://www.zhipin.com/web/geek/jobs*"
            ],
            "run_at": "document_end"
        }
    ],
    "permissions": [
        "storage",
        "downloads"
    ],
    "host_permissions": [
        "https://www.zhaopin.com/*",
        "https://www.yupao.com/*",
        "https://www.zhipin.com/*"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "zelto@sapling.ink",
            "strict_min_version": "109.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    }
}